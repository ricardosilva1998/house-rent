---
import { createT, type Locale, locales, pathInLocale } from '../i18n/use-translation';

const locale: Locale = (Astro.locals.locale as Locale) ?? 'pt';
const t = createT(locale);
const user = Astro.locals.user;
const path = Astro.url.pathname;
const stripLocale = (p: string) => {
  const parts = p.split('/').filter(Boolean);
  if (parts[0] && (locales as readonly string[]).includes(parts[0])) parts.shift();
  return '/' + parts.join('/');
};
const naked = stripLocale(path);
---
<style>
  .site-mobile-menu {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 40;
    overflow-y: auto;
    flex-direction: column;
  }
  .site-mobile-menu.open { display: flex; }
  .site-mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 39;
    background: rgba(31, 26, 20, 0.5);
  }
  .site-mobile-overlay.open { display: block; }
  .site-hamburger {
    display: none;
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 2px;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--ink);
    transition: background-color 160ms ease, color 160ms ease;
    flex-shrink: 0;
    margin-left: auto;
  }
  .site-hamburger:hover { background: var(--ink); color: var(--paper); }
  @media (max-width: 767px) {
    .site-hamburger { display: flex; }
    .site-desktop-nav,
    .site-desktop-controls { display: none !important; }
  }
</style>

<!-- Tap-outside overlay (mobile) -->
<div id="site-mobile-overlay" class="site-mobile-overlay" aria-hidden="true"></div>

<!-- Full-screen mobile menu -->
<div
  id="site-mobile-menu"
  class="site-mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label={locale === 'en' ? 'Site navigation' : locale === 'es' ? 'Navegación del sitio' : 'Navegação do site'}
  style="background: var(--paper);"
>
  <!-- Mobile menu header row -->
  <div class="flex items-center justify-between px-6 h-16 border-b shrink-0" style="border-color: var(--rule);">
    <a href={pathInLocale('/', locale)}>
      <span class="display-italic text-[22px] tracking-tight" style="color: var(--ink);">Retiro dos Baeta</span>
    </a>
    <button
      id="site-menu-close"
      aria-label={locale === 'en' ? 'Close menu' : locale === 'es' ? 'Cerrar menú' : 'Fechar menu'}
      style="display:flex; background:transparent; border:1px solid var(--rule); border-radius:2px; width:40px; height:40px; align-items:center; justify-content:center; cursor:pointer; color:var(--ink); transition:background-color 160ms ease,color 160ms ease;"
    >
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <path d="M2 2L14 14M14 2L2 14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- Nav links -->
  <nav class="flex flex-col px-6 py-10 gap-2" aria-label={locale === 'en' ? 'Main navigation' : locale === 'es' ? 'Navegación principal' : 'Navegação principal'}>
    <a href={pathInLocale('/casa', locale)} class="display-italic text-[clamp(28px,8vw,40px)]" style="color: var(--ink);">{t('nav.house')}</a>
    <a href={pathInLocale('/reservar', locale)} class="display-italic text-[clamp(28px,8vw,40px)]" style="color: var(--ink);">{t('nav.book')}</a>
    {user ? (
      user.role === 'admin' ? (
        <a href="/admin" class="display-italic text-[clamp(28px,8vw,40px)]" style="color: var(--ink);">Admin</a>
      ) : (
        <a href={pathInLocale('/conta', locale)} class="display-italic text-[clamp(28px,8vw,40px)]" style="color: var(--ink);">{user.name.split(' ')[0]}</a>
      )
    ) : (
      <a href={pathInLocale('/conta/login', locale)} class="display-italic text-[clamp(28px,8vw,40px)]" style="color: var(--ink);">{t('nav.login')}</a>
    )}
  </nav>

  <!-- Locale switcher -->
  <div class="mt-auto px-6 pb-10 pt-6 border-t" style="border-color: var(--rule);">
    <div class="flex items-center gap-4">
      {locales.map((l) => (
        <a
          href={pathInLocale(naked === '/' ? '/' : naked, l)}
          class={`numeral text-[11px] tracking-[0.18em] uppercase transition-colors ${l === locale ? '' : 'opacity-50 hover:opacity-100'}`}
          style={l === locale ? 'color: var(--ember);' : 'color: var(--ink);'}
          aria-current={l === locale ? 'true' : undefined}
        >
          {l}
        </a>
      ))}
    </div>
  </div>
</div>

<!-- Sticky top bar -->
<header class="sticky top-0 z-30 backdrop-blur-sm" style="background: color-mix(in oklab, var(--paper) 88%, transparent);">
  <div class="border-b" style="border-color: var(--rule);">
    <div class="max-w-[1320px] mx-auto px-6 lg:px-10 h-16 flex items-center gap-10">
      <!-- Logo — always visible -->
      <a href={pathInLocale('/', locale)} class="flex items-center gap-3 group">
        <span class="display-italic text-[26px] tracking-tight" style="color: var(--ink);">Retiro dos Baeta</span>
      </a>

      <!-- Desktop nav (hidden below md) -->
      <nav class="site-desktop-nav ml-auto flex items-center gap-7 dateline">
        <a href={pathInLocale('/casa', locale)} class="elink">{t('nav.house')}</a>
        <a href={pathInLocale('/reservar', locale)} class="elink">{t('nav.book')}</a>
      </nav>

      <!-- Desktop locale + auth (hidden below md) -->
      <div class="site-desktop-controls flex items-center gap-4 pl-4 ml-4 border-l" style="border-color: var(--rule);">
        <div class="flex items-center gap-2">
          {locales.map((l) => (
            <a
              href={pathInLocale(naked === '/' ? '/' : naked, l)}
              class={`numeral text-[11px] tracking-[0.18em] uppercase transition-colors ${l === locale ? '' : 'opacity-50 hover:opacity-100'}`}
              style={l === locale ? 'color: var(--ember);' : 'color: var(--ink);'}
              aria-current={l === locale ? 'true' : undefined}
            >
              {l}
            </a>
          ))}
        </div>
        {user ? (
          user.role === 'admin' ? (
            <a href="/admin" class="numeral text-[11px] tracking-[0.18em] uppercase px-2.5 py-1 inline-flex items-center gap-2" style="background: var(--ink); color: var(--paper);">
              <span style="width: 6px; height: 6px; border-radius: 50%; background: var(--ember);"></span>
              {user.name.split(' ')[0]}
            </a>
          ) : (
            <a href={pathInLocale('/conta', locale)} class="dateline elink">
              {user.name.split(' ')[0]}
            </a>
          )
        ) : (
          <a href={pathInLocale('/conta/login', locale)} class="dateline elink">
            {t('nav.login')}
          </a>
        )}
      </div>

      <!-- Hamburger (mobile only, hidden above md via CSS) -->
      <button
        id="site-menu-toggle"
        class="site-hamburger"
        aria-label={locale === 'en' ? 'Open menu' : locale === 'es' ? 'Abrir menú' : 'Abrir menu'}
        aria-expanded="false"
        aria-controls="site-mobile-menu"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <rect y="2" width="18" height="2" rx="1" fill="currentColor"/>
          <rect y="8" width="18" height="2" rx="1" fill="currentColor"/>
          <rect y="14" width="18" height="2" rx="1" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('site-menu-toggle');
  const closeBtn = document.getElementById('site-menu-close');
  const menu = document.getElementById('site-mobile-menu');
  const overlay = document.getElementById('site-mobile-overlay');

  function openMenu() {
    menu?.classList.add('open');
    overlay?.classList.add('open');
    toggle?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }
  function closeMenu() {
    menu?.classList.remove('open');
    overlay?.classList.remove('open');
    toggle?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  toggle?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
  overlay?.addEventListener('click', closeMenu);
</script>
