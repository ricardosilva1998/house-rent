---
import { createT, type Locale } from '../i18n/use-translation';
const locale: Locale = (Astro.locals.locale as Locale) ?? 'pt';
const t = createT(locale);
const year = new Date().getFullYear();
---
<footer class="mt-16 border-t border-stone-200 bg-white">
  <div class="max-w-6xl mx-auto px-4 py-8 text-sm text-stone-500 flex flex-wrap items-center justify-between gap-4">
    <span>© {year} {t('site.name')}</span>
    <span class="text-xs">{t('site.tagline')}</span>
  </div>
</footer>
