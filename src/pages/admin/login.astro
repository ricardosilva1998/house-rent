---
import '../../styles/global.css';
import AdminAuthForm from '../../components/admin/AdminAuthForm.tsx';

if (Astro.locals.user?.role === 'admin') {
  return Astro.redirect('/admin');
}

const next = Astro.url.searchParams.get('next') ?? undefined;
---
<!doctype html>
<html lang="pt">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#F5F1EB" />
    <title>Admin · Retiro dos Baeta</title>
  </head>
  <body class="min-h-screen flex items-center justify-center px-6">
    <main class="relative w-full max-w-[440px]">
      <a href="/" class="absolute -top-16 left-0 dateline elink">← {`{ Voltar ao site }`.replace(/[{}]/g, '').trim()}</a>

      <div class="text-center mb-10">
        <p class="serial mb-4" style="color: var(--ember);">Acesso restrito · Edição de gestão</p>
        <hr class="rule-strong w-12 mx-auto mb-6" />
        <p class="display-italic text-[clamp(40px,5vw,56px)] leading-[1.02]" style="color: var(--ink);">
          Retiro dos Baeta
        </p>
        <p class="dateline mt-3">Painel administrativo · Nº 01</p>
      </div>

      <div class="border-t border-b py-10" style="border-color: var(--rule);">
        <AdminAuthForm client:load next={next} />
      </div>

      <p class="dateline text-center mt-8" style="color: var(--ink-faint);">
        Apenas para administradores autorizados.
      </p>
    </main>
  </body>
</html>
