---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { createT, type Locale, pathInLocale } from '../../i18n/use-translation';
import { eq } from 'drizzle-orm';
import { db } from '../../db/client';
import { users } from '../../db/schema';
import { consumeUserToken } from '../../lib/auth';

const locale: Locale = (Astro.locals.locale as Locale) ?? 'pt';
const t = createT(locale);
const token = Astro.url.searchParams.get('token');
let status: 'pending' | 'ok' | 'invalid' = 'pending';

if (token) {
  const userId = await consumeUserToken(token, 'verify_email');
  if (userId) {
    await db.update(users).set({ emailVerifiedAt: new Date() }).where(eq(users.id, userId));
    status = 'ok';
  } else {
    status = 'invalid';
  }
}
---
<SiteLayout title={t('auth.verify_title')}>
  <section class="max-w-md mx-auto px-6 lg:px-10 py-20 lg:py-28 text-center">
    <p class="serial mb-3">Conta · Verification</p>
    <hr class="rule-strong w-12 mx-auto mb-6" />
    <h1 class="display text-[clamp(40px,5vw,72px)] mb-6" style="text-wrap: balance;">{t('auth.verify_title')}</h1>
    {!token && <p class="display-italic text-[18px]" style="color: var(--ink-muted);">{t('auth.verify_body')}</p>}
    {status === 'ok' && (
      <>
        <p class="dateline mb-8" style="color: var(--sage);">✓ {locale === 'en' ? 'Email verified' : locale === 'es' ? 'Email verificado' : 'Email confirmado'}</p>
        <a href={pathInLocale('/reservar', locale)} class="btn-primary">
          {t('nav.book')} <span aria-hidden="true">→</span>
        </a>
      </>
    )}
    {status === 'invalid' && <p class="dateline mt-8" style="color: var(--ember);">{t('errors.generic')}</p>}
  </section>
</SiteLayout>
