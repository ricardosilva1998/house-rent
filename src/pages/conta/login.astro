---
import SiteLayout from '../../layouts/SiteLayout.astro';
import AuthForms from '../../components/islands/AuthForms.tsx';
import { createT, type Locale, pathInLocale } from '../../i18n/use-translation';

if (Astro.locals.user) return Astro.redirect(pathInLocale('/conta', Astro.locals.locale));

const locale: Locale = (Astro.locals.locale as Locale) ?? 'pt';
const t = createT(locale);
const next = Astro.url.searchParams.get('next') ?? undefined;
---
<SiteLayout title={t('auth.login_title')}>
  <section class="max-w-md mx-auto px-6 lg:px-10 py-20 lg:py-28">
    <p class="serial mb-3">Conta · Account</p>
    <hr class="rule-strong w-12 mb-6" />
    <h1 class="display text-[clamp(40px,5vw,72px)] mb-8" style="text-wrap: balance;">{t('auth.login_title')}</h1>
    <AuthForms
      client:load
      mode="login"
      next={next}
      labels={{
        email: t('auth.email'),
        password: t('auth.password'),
        name: t('auth.name'),
        phone: t('auth.phone'),
        country: t('auth.country'),
        submit: t('auth.login_submit'),
        forgot: t('auth.forgot'),
        new_password: t('auth.password'),
        error_invalid_credentials: t('errors.invalid_credentials'),
        error_email_exists: t('errors.email_exists'),
        error_generic: t('errors.generic'),
        success_check_email: t('auth.verify_body'),
        success_password_reset: 'OK'
      }}
    />
    <hr class="rule mt-12 mb-6" />
    <p class="dateline flex flex-wrap gap-x-8 gap-y-2">
      <a href={pathInLocale('/conta/registar', locale)} class="elink">{t('auth.register_title')} ↗</a>
      <a href={pathInLocale('/conta/recuperar', locale)} class="elink">{t('auth.forgot')} ↗</a>
    </p>
  </section>
</SiteLayout>
