---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { createT, type Locale, pathInLocale } from '../../../i18n/use-translation';
import { db } from '../../../db/client';
import { bookings } from '../../../db/schema';
import { and, eq, gte, desc, asc, lt } from 'drizzle-orm';

const user = Astro.locals.user;
const locale: Locale = (Astro.locals.locale as Locale) ?? 'pt';
const t = createT(locale);
if (!user) return Astro.redirect(pathInLocale('/conta/login', locale));

const today = new Date().toISOString().slice(0, 10);
const upcoming = await db
  .select()
  .from(bookings)
  .where(and(eq(bookings.userId, user.id), gte(bookings.checkIn, today)))
  .orderBy(asc(bookings.checkIn));
const past = await db
  .select()
  .from(bookings)
  .where(and(eq(bookings.userId, user.id), lt(bookings.checkIn, today)))
  .orderBy(desc(bookings.checkIn))
  .limit(20);
---
<SiteLayout title={t('account.title')}>
  <section class="max-w-3xl mx-auto px-4 py-12">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-2xl font-semibold">{t('account.title')}</h1>
      <form method="POST" action="/api/auth/logout">
        <button class="text-sm text-stone-600 underline" type="submit">{t('auth.logout')}</button>
      </form>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      <section class="rounded-lg border border-stone-200 bg-white p-5">
        <h2 class="font-medium mb-1">{t('account.profile')}</h2>
        <p class="text-stone-600 text-sm">{user.name}</p>
        <p class="text-stone-500 text-sm">{user.email}</p>
        {!user.emailVerifiedAt && (
          <p class="text-amber-700 text-sm mt-3">{t('auth.verify_body')}</p>
        )}
      </section>

      <section class="rounded-lg border border-stone-200 bg-white p-5">
        <h2 class="font-medium mb-3">{t('account.upcoming')}</h2>
        {upcoming.length === 0 ? (
          <p class="text-stone-500 text-sm">—</p>
        ) : (
          <ul class="text-sm space-y-2">
            {upcoming.map((b) => (
              <li class="flex justify-between">
                <span>{b.checkIn} → {b.checkOut}</span>
                <span class="font-mono text-stone-500">{b.confirmationCode}</span>
              </li>
            ))}
          </ul>
        )}
      </section>
    </div>

    {past.length > 0 && (
      <section class="mt-8 rounded-lg border border-stone-200 bg-white p-5">
        <h2 class="font-medium mb-3">{t('account.past')}</h2>
        <ul class="text-sm space-y-2">
          {past.map((b) => (
            <li class="flex justify-between text-stone-700">
              <span>{b.checkIn} → {b.checkOut}</span>
              <span class="font-mono text-stone-500">{b.confirmationCode}</span>
            </li>
          ))}
        </ul>
      </section>
    )}
  </section>
</SiteLayout>
