---
import SiteLayout from '../../../layouts/SiteLayout.astro';
import { createT, type Locale, pathInLocale } from '../../../i18n/use-translation';
import { eq } from 'drizzle-orm';
import { db } from '../../../db/client';
import { users } from '../../../db/schema';
import { consumeUserToken } from '../../../lib/auth';

const locale: Locale = (Astro.locals.locale as Locale) ?? 'pt';
const t = createT(locale);
const token = Astro.url.searchParams.get('token');
let status: 'pending' | 'ok' | 'invalid' = 'pending';

if (token) {
  const userId = await consumeUserToken(token, 'verify_email');
  if (userId) {
    await db.update(users).set({ emailVerifiedAt: new Date() }).where(eq(users.id, userId));
    status = 'ok';
  } else {
    status = 'invalid';
  }
}
---
<SiteLayout title={t('auth.verify_title')}>
  <section class="max-w-md mx-auto px-4 py-12 text-center">
    <h1 class="text-2xl font-semibold mb-4">{t('auth.verify_title')}</h1>
    {!token && <p class="text-stone-600">{t('auth.verify_body')}</p>}
    {status === 'ok' && (
      <>
        <p class="text-emerald-700 mb-4">✔</p>
        <a href={pathInLocale('/reservar', locale)} class="inline-block px-4 py-2 rounded-md bg-stone-900 text-white">
          {t('nav.book')}
        </a>
      </>
    )}
    {status === 'invalid' && <p class="text-red-600">{t('errors.generic')}</p>}
  </section>
</SiteLayout>
