---
import SiteLayout from '../layouts/SiteLayout.astro';
import BookingFlow from '../components/islands/BookingFlow.tsx';
import { createT, type Locale, pathInLocale } from '../i18n/use-translation';
import { getDefaultProperty } from '../lib/property';

const locale: Locale = (Astro.locals.locale as Locale) ?? 'pt';
const t = createT(locale);
const user = Astro.locals.user;
const property = await getDefaultProperty();

const labels = {
  select_dates: t('booking.select_dates'),
  check_in: t('booking.check_in'),
  check_out: t('booking.check_out'),
  guests: t('booking.guests'),
  total: t('booking.total'),
  confirm: t('booking.confirm'),
  no_dates: t('booking.no_dates'),
  unavailable: t('booking.unavailable'),
  login_required:
    locale === 'en' ? 'Please log in to book your stay.' :
    locale === 'es' ? 'Inicia sesión para reservar.' :
    'Inicie sessão para reservar a sua estadia.',
  email_not_verified: t('errors.email_not_verified'),
  cta_login: t('nav.login'),
  special_requests:
    locale === 'en' ? 'Notes for the host' :
    locale === 'es' ? 'Notas para el anfitrión' :
    'Notas para o anfitrião'
};

const nightsLabel = (n: number) =>
  locale === 'en' ? (n === 1 ? '1 night' : `${n} nights`) :
  locale === 'es' ? (n === 1 ? '1 noche' : `${n} noches`) :
  (n === 1 ? '1 noite' : `${n} noites`);
const minStayLabel = (n: number) =>
  locale === 'en' ? `Minimum stay: ${n} nights` :
  locale === 'es' ? `Estancia mínima: ${n} noches` :
  `Estadia mínima de ${n} noites`;

const accountLabel =
  locale === 'en' ? 'My account' :
  locale === 'es' ? 'Mi cuenta' :
  'A minha conta';
const labelsForClient = { ...labels, nights: nightsLabel, min_stay: minStayLabel, account: accountLabel };
---
<SiteLayout title={t('nav.book')}>
  <header class="pt-12 lg:pt-20 pb-12">
    <div class="max-w-[1320px] mx-auto px-6 lg:px-10">
      <p class="reveal reveal-1 dateline mb-4">{locale === 'en' ? 'Reservations · ' : locale === 'es' ? 'Reservas · ' : 'Reservas · '}{property?.name ?? ''}</p>
      <h1 class="reveal reveal-2 display text-[clamp(48px,7.5vw,120px)]" style="text-wrap: balance;">
        {locale === 'en' ? 'Choose your nights' : locale === 'es' ? 'Elige tus noches' : 'Escolha as suas noites'}
      </h1>
      <p class="reveal reveal-3 mt-5 display-italic text-[clamp(18px,1.6vw,24px)] max-w-2xl" style="color: var(--ink-muted);">
        {locale === 'en'
          ? 'Each stay is private — only your party occupies the house.'
          : locale === 'es'
          ? 'Cada estancia es privada — solo tu grupo ocupa la casa.'
          : 'Cada estadia é privada — apenas o seu grupo ocupa a casa.'}
      </p>
    </div>
  </header>

  <section class="pb-32">
    <div class="max-w-[1320px] mx-auto px-6 lg:px-10">
      {!property ? (
        <p class="dateline">—</p>
      ) : (
        <BookingFlow
          client:load
          loginPath={pathInLocale('/conta/login?next=/reservar', locale)}
          accountPath={pathInLocale('/conta', locale)}
          initialUser={user ? { id: user.id, name: user.name, emailVerified: !!user.emailVerifiedAt } : null}
          maxGuests={property.maxGuests}
          currency={property.currency}
          labels={labelsForClient}
        />
      )}
    </div>
  </section>
</SiteLayout>
