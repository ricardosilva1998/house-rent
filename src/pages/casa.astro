---
import SiteLayout from '../layouts/SiteLayout.astro';
import { createT, type Locale, pathInLocale } from '../i18n/use-translation';
import { getDefaultProperty, getPropertyPhotos, getAllAmenities, getPropertyAmenityIds } from '../lib/property';
import { db } from '../db/client';
import { propertyTranslations } from '../db/schema';
import { eq, and } from 'drizzle-orm';

const locale: Locale = (Astro.locals.locale as Locale) ?? 'pt';
const t = createT(locale);
const property = await getDefaultProperty();
const photos = property ? await getPropertyPhotos(property.id) : [];
const amenitiesAll = await getAllAmenities(locale);
const selected = property ? await getPropertyAmenityIds(property.id) : new Set<string>();
const amenitiesActive = amenitiesAll.filter((a) => selected.has(a.id));
const trRows = property
  ? await db
      .select()
      .from(propertyTranslations)
      .where(and(eq(propertyTranslations.propertyId, property.id), eq(propertyTranslations.locale, locale)))
  : [];
const tr = trRows[0];
---
<SiteLayout title={property?.name ?? t('site.name')}>
  <section class="max-w-6xl mx-auto px-4 py-10">
    <h1 class="text-3xl font-semibold tracking-tight">{property?.name ?? t('site.name')}</h1>
    <p class="text-stone-600 mt-1">{[property?.city, property?.region].filter(Boolean).join(', ')}</p>
    {photos.length > 0 && (
      <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-3">
        <div class="md:col-span-2 md:row-span-2 aspect-[4/3] rounded-lg overflow-hidden bg-stone-200">
          <img src={photos[0]!.url} alt={photos[0]!.altText ?? ''} class="w-full h-full object-cover" />
        </div>
        {photos.slice(1, 5).map((p) => (
          <div class="aspect-square rounded-lg overflow-hidden bg-stone-200">
            <img src={p.url} alt={p.altText ?? ''} class="w-full h-full object-cover" />
          </div>
        ))}
      </div>
    )}

    <div class="mt-10 grid md:grid-cols-3 gap-8">
      <article class="md:col-span-2">
        <p class="text-stone-700 whitespace-pre-line leading-relaxed">{tr?.description ?? ''}</p>

        {amenitiesActive.length > 0 && (
          <section class="mt-10">
            <h2 class="text-xl font-semibold mb-3">{t('home.amenities_title')}</h2>
            <ul class="grid grid-cols-2 sm:grid-cols-3 gap-2 text-sm">
              {amenitiesActive.map((a) => (
                <li class="rounded-md border border-stone-200 bg-white px-3 py-2">{a.label}</li>
              ))}
            </ul>
          </section>
        )}

        {property?.houseRules && (
          <section class="mt-10">
            <h2 class="text-xl font-semibold mb-3">{t('home.rules_title')}</h2>
            <p class="text-stone-700 whitespace-pre-line text-sm">{property.houseRules}</p>
          </section>
        )}
      </article>

      <aside class="rounded-lg border border-stone-200 bg-white p-5 h-fit md:sticky md:top-20">
        <p class="text-sm text-stone-500">{t('booking.total')}</p>
        <p class="text-2xl font-semibold">
          {property ? `${property.basePrice.toFixed(0)} ${property.currency}` : '—'}
          <span class="text-sm font-normal text-stone-500"> / {t('booking.nights', { n: 1 })}</span>
        </p>
        <p class="mt-3 text-sm text-stone-500">
          {property ? `${property.maxGuests} ${t('booking.guests').toLowerCase()} · ${property.bedrooms} quartos · ${property.beds} camas` : ''}
        </p>
        <a href={pathInLocale('/reservar', locale)} class="mt-4 block text-center rounded-md bg-stone-900 text-white px-4 py-2 text-sm font-medium">
          {t('home.hero_cta')}
        </a>
      </aside>
    </div>
  </section>
</SiteLayout>
