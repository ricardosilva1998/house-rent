---
import '../styles/global.css';

interface Props {
  title?: string;
}

const user = Astro.locals.user;
const path = Astro.url.pathname;
const { title } = Astro.props;
const nav = [
  { href: '/admin', label: 'Dashboard' },
  { href: '/admin/bookings', label: 'Reservas' },
  { href: '/admin/property', label: 'Casa' },
  { href: '/admin/pricing', label: 'Preços' },
  { href: '/admin/calendar-sync', label: 'iCal' },
  { href: '/admin/users', label: 'Utilizadores' },
  { href: '/admin/settings', label: 'Definições' }
];
---
<!doctype html>
<html lang="pt" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title ? `${title} — Admin` : 'Admin'} — Retiro dos Baeta</title>
  </head>
  <body class="h-full bg-stone-100 text-stone-900 font-sans antialiased">
    <div class="min-h-full flex">
      <aside class="w-60 shrink-0 bg-stone-900 text-stone-100 flex flex-col">
        <div class="px-5 py-5 border-b border-stone-700/40">
          <a href="/admin" class="font-semibold tracking-tight block">Retiro dos Baeta</a>
          <span class="text-xs text-stone-400">Admin</span>
        </div>
        <nav class="flex-1 py-4">
          {nav.map((item) => {
            const active = item.href === '/admin' ? path === item.href : path.startsWith(item.href);
            return (
              <a
                href={item.href}
                class={`block px-5 py-2 text-sm ${active ? 'bg-stone-800 text-white' : 'text-stone-300 hover:bg-stone-800/50 hover:text-white'}`}
              >
                {item.label}
              </a>
            );
          })}
        </nav>
        <div class="px-5 py-4 border-t border-stone-700/40 text-xs text-stone-400">
          <div>{user?.name}</div>
          <form method="POST" action="/api/auth/logout" class="mt-2">
            <button type="submit" class="underline">Sair</button>
          </form>
        </div>
      </aside>
      <main class="flex-1 flex flex-col">
        <header class="h-14 border-b border-stone-200 bg-white flex items-center px-6">
          <h1 class="font-medium text-stone-900">{title}</h1>
        </header>
        <div class="flex-1 p-6">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
