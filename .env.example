# Public site URL used for canonical links and email templates
PUBLIC_SITE_URL=http://localhost:4321

# Database (libSQL/SQLite). For Turso prod use libsql://<db>.turso.io with TOKEN
DATABASE_URL=file:./data/dev.db
DATABASE_AUTH_TOKEN=

# Auth secrets — generate with `openssl rand -base64 32`
SESSION_SECRET=replace-me-in-production
CRON_SECRET=replace-me-in-production

# Email provider (Resend). Leave empty in dev to log emails to stdout.
RESEND_API_KEY=
EMAIL_FROM=Retiro dos Baeta <noreply@example.com>

# Anthropic API key for AI price suggestions
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
AI_PRICING_MONTHLY_BUDGET_EUR=5

# Default locale (matches astro.config.mjs)
DEFAULT_LOCALE=pt
